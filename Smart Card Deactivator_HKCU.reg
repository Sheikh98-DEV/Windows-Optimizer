"Start"=dword:00000004
[HKEY_CURRENT_USER\SYSTEM\ControlSet001\Services\SCPolicySvc]
"Start"=dword:00000004
[HKEY_CURRENT_USER\SYSTEM\ControlSet001\Services\CertPropSvc]
"Start"=dword:00000004
